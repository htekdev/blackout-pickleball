---
/**
 * CommunityCarousel — Horizontal auto-playing photo carousel
 * Uses CSS scroll-snap for smooth native scrolling + IntersectionObserver for auto-play.
 * Zero external dependencies. Responsive mobile & desktop.
 *
 * Props:
 * - photos: Array of { src, alt, caption?, credit? }
 * - autoPlay?: boolean (default true)
 * - interval?: number in ms (default 4000)
 * - showDots?: boolean (default true)
 * - title?: string (section heading)
 * - subtitle?: string (section subheading)
 */

interface Photo {
  src: string;
  alt: string;
  caption?: string;
  credit?: string;
}

interface Props {
  photos: Photo[];
  autoPlay?: boolean;
  interval?: number;
  showDots?: boolean;
  title?: string;
  subtitle?: string;
}

const {
  photos,
  autoPlay = true,
  interval = 4000,
  showDots = true,
  title,
  subtitle,
} = Astro.props;

const carouselId = `carousel-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="py-12 sm:py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Section Header */}
    {(title || subtitle) && (
      <div class="text-center mb-10">
        {subtitle && (
          <p class="text-gray-500 font-semibold text-sm uppercase tracking-widest mb-3">{subtitle}</p>
        )}
        {title && (
          <h2 class="text-3xl sm:text-4xl font-black text-black">{title}</h2>
        )}
      </div>
    )}

    {/* Carousel Container */}
    <div
      id={carouselId}
      class="community-carousel relative group"
      data-autoplay={autoPlay.toString()}
      data-interval={interval.toString()}
    >
      {/* Navigation Arrows */}
      <button
        class="carousel-prev absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 sm:w-12 sm:h-12 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-black/20"
        aria-label="Previous photo"
      >
        <svg class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        class="carousel-next absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 sm:w-12 sm:h-12 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-black/20"
        aria-label="Next photo"
      >
        <svg class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      {/* Scrollable Track */}
      <div class="carousel-track flex gap-4 sm:gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 -mx-4 px-4 sm:-mx-6 sm:px-6 scrollbar-hide">
        {photos.map((photo, index) => (
          <div
            class="carousel-slide flex-shrink-0 w-[85vw] sm:w-[60vw] md:w-[45vw] lg:w-[35vw] snap-center"
            data-index={index}
          >
            <div class="relative overflow-hidden rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 aspect-[4/3]">
              <img
                src={photo.src}
                alt={photo.alt}
                loading={index < 3 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              />
              {/* Overlay gradient for caption */}
              {(photo.caption || photo.credit) && (
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300">
                  <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6">
                    {photo.caption && (
                      <p class="text-white text-sm sm:text-base font-semibold leading-snug">{photo.caption}</p>
                    )}
                    {photo.credit && (
                      <p class="text-white/70 text-xs sm:text-sm mt-1">📸 {photo.credit}</p>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Dot Indicators */}
      {showDots && photos.length > 1 && (
        <div class="carousel-dots flex justify-center gap-2 mt-6">
          {photos.map((_, index) => (
            <button
              class="carousel-dot w-2 h-2 rounded-full bg-black/20 transition-all duration-300 hover:bg-black/40 focus:outline-none focus:ring-2 focus:ring-black/20 focus:ring-offset-2"
              data-index={index}
              aria-label={`Go to photo ${index + 1}`}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar but keep scroll functionality */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Active dot indicator */
  .carousel-dot.active {
    background-color: rgb(0 0 0 / 0.8);
    width: 1.5rem;
    border-radius: 9999px;
  }

  /* Touch-friendly: always show arrows on mobile */
  @media (max-width: 640px) {
    .carousel-prev,
    .carousel-next {
      opacity: 0.7 !important;
    }
  }
</style>

<script define:vars={{ carouselId, autoPlay, interval }}>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById(carouselId);
    if (!container) return;

    const track = container.querySelector('.carousel-track');
    const slides = container.querySelectorAll('.carousel-slide');
    const dots = container.querySelectorAll('.carousel-dot');
    const prevBtn = container.querySelector('.carousel-prev');
    const nextBtn = container.querySelector('.carousel-next');

    if (!track || slides.length === 0) return;

    let currentIndex = 0;
    let autoPlayTimer = null;
    let isHovered = false;
    let isUserScrolling = false;
    let scrollTimeout = null;

    // Update active dot
    function updateDots(index) {
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
    }

    // Scroll to specific slide
    function goToSlide(index) {
      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;
      currentIndex = index;

      const slide = slides[index];
      const trackRect = track.getBoundingClientRect();
      const slideRect = slide.getBoundingClientRect();
      const scrollLeft = slide.offsetLeft - track.offsetLeft - (trackRect.width - slideRect.width) / 2;

      track.scrollTo({ left: scrollLeft, behavior: 'smooth' });
      updateDots(currentIndex);
    }

    // Auto-play logic
    function startAutoPlay() {
      if (!autoPlay || isHovered) return;
      stopAutoPlay();
      autoPlayTimer = setInterval(() => {
        if (!isHovered && !isUserScrolling) {
          goToSlide(currentIndex + 1);
        }
      }, interval);
    }

    function stopAutoPlay() {
      if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
      }
    }

    // Detect current slide from scroll position
    function detectCurrentSlide() {
      const trackRect = track.getBoundingClientRect();
      const trackCenter = trackRect.left + trackRect.width / 2;
      let closestIndex = 0;
      let closestDistance = Infinity;

      slides.forEach((slide, i) => {
        const slideRect = slide.getBoundingClientRect();
        const slideCenter = slideRect.left + slideRect.width / 2;
        const distance = Math.abs(slideCenter - trackCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = i;
        }
      });

      if (closestIndex !== currentIndex) {
        currentIndex = closestIndex;
        updateDots(currentIndex);
      }
    }

    // Event listeners
    prevBtn?.addEventListener('click', () => {
      goToSlide(currentIndex - 1);
      stopAutoPlay();
      startAutoPlay();
    });

    nextBtn?.addEventListener('click', () => {
      goToSlide(currentIndex + 1);
      stopAutoPlay();
      startAutoPlay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goToSlide(i);
        stopAutoPlay();
        startAutoPlay();
      });
    });

    // Track manual scrolling
    track.addEventListener('scroll', () => {
      isUserScrolling = true;
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        isUserScrolling = false;
        detectCurrentSlide();
      }, 150);
    }, { passive: true });

    // Pause on hover
    container.addEventListener('mouseenter', () => {
      isHovered = true;
      stopAutoPlay();
    });

    container.addEventListener('mouseleave', () => {
      isHovered = false;
      startAutoPlay();
    });

    // Pause when not visible (performance)
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          startAutoPlay();
        } else {
          stopAutoPlay();
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(container);

    // Initialize
    updateDots(0);
    startAutoPlay();

    // Touch support: pause auto-play during touch
    track.addEventListener('touchstart', () => {
      isUserScrolling = true;
      stopAutoPlay();
    }, { passive: true });

    track.addEventListener('touchend', () => {
      setTimeout(() => {
        isUserScrolling = false;
        detectCurrentSlide();
        startAutoPlay();
      }, 300);
    }, { passive: true });
  });
</script>
