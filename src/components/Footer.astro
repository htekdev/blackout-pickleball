---
const year = new Date().getFullYear();
const socialLinks = [
  { href: 'https://www.instagram.com/blackoutpickleball', label: 'Instagram', icon: 'instagram' },
  { href: 'https://www.facebook.com/blackoutpickleball', label: 'Facebook', icon: 'facebook' },
  { href: 'https://www.tiktok.com/@blackoutpickleball', label: 'TikTok', icon: 'tiktok' },
];
---

<footer class="bg-blackout text-text-inverse">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <span class="text-xl font-black tracking-tight uppercase">
          Blackout<span class="text-accent">.</span>
        </span>
        <p class="mt-3 text-sm text-white/60 max-w-xs">
          Celebrate Diversity. Play with Purpose. Performance gear for pickleball players who play bold.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/shop" class="text-sm text-white/60 hover:text-white transition-colors">Shop</a></li>
          <li><a href="/about" class="text-sm text-white/60 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/events" class="text-sm text-white/60 hover:text-white transition-colors">Events</a></li>
          <li><a href="/contact" class="text-sm text-white/60 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal + Social -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-white/60 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-white/60 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
        <div class="flex gap-4 mt-6">
          {socialLinks.map(({ href, label }) => (
            <a href={href} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-accent transition-colors" aria-label={label}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-white/10 text-center">
      <p class="text-xs text-white/40">
        &copy; {year} Blackout Pickleball. All rights reserved. Built by <a href="https://htek.dev" class="text-accent hover:underline" target="_blank">HTEK</a>.
      </p>
    </div>
  </div>
</footer>
