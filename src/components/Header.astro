---
import CartIcon from './CartIcon';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/shop', label: 'Shop' },
  { href: '/about', label: 'About' },
  { href: '/events', label: 'Events' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-blackout text-text-inverse sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <span class="text-xl sm:text-2xl font-black tracking-tight uppercase">
          Blackout<span class="text-accent">.</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium tracking-wide uppercase transition-colors hover:text-accent',
              currentPath === href ? 'text-accent' : 'text-white/80',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Cart + Mobile Menu -->
      <div class="flex items-center gap-4">
        <CartIcon client:only="preact" />

        <!-- Mobile Menu Toggle -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 text-white/80 hover:text-accent transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col gap-2">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2 text-sm font-medium tracking-wide uppercase rounded-lg transition-colors',
              currentPath === href ? 'bg-accent text-blackout' : 'text-white/80 hover:bg-white/10',
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>
