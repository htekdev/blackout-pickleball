---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Blackout Pickleball — questions, partnerships, and community inquiries.">

  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Get in Touch</p>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight">Contact Us</h1>
        <p class="mt-4 text-text-light text-lg">Have a question, want to partner, or just want to say hey? Reach out!</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Contact Info -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
          <h2 class="text-xl font-bold mb-6">Reach Out</h2>
          <div class="space-y-4">
            <div>
              <h3 class="text-sm font-semibold text-text-light uppercase tracking-wider">Email</h3>
              <a href="mailto:info@brandblackout.com" class="text-accent hover:text-accent-dark transition-colors font-medium">info@brandblackout.com</a>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-light uppercase tracking-wider">Social Media</h3>
              <div class="flex gap-4 mt-2">
                <a href="https://www.instagram.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm">Instagram</a>
                <a href="https://www.facebook.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm">Facebook</a>
                <a href="https://www.tiktok.com/@blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm">TikTok</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Partnership CTA -->
        <div class="bg-blackout text-text-inverse rounded-2xl p-8">
          <h2 class="text-xl font-bold mb-4">Partnerships & Collaborations</h2>
          <p class="text-white/70 leading-relaxed">
            Interested in partnering with Blackout Pickleball? Whether you're a brand, venue, or community organizer — we'd love to connect.
          </p>
          <a href="mailto:info@brandblackout.com" class="inline-flex items-center mt-6 px-6 py-2.5 bg-accent hover:bg-accent-dark text-blackout font-bold rounded-lg transition-colors text-sm uppercase tracking-wider">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
