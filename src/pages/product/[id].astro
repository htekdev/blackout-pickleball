---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AddToCartButton from '../../components/AddToCartButton';
import ProductViewer from '../../components/ProductViewer';
import type { CatalogItem } from '../../lib/stripe';
import { findProduct, toCatalogItem, PRODUCT_CATALOG } from '../../lib/products';

const { id } = Astro.params;

let product: (CatalogItem & { colorName?: string; colorHex?: string; category?: string }) | null = null;
let isDemo = false;
let fullDescription = '';

try {
  const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
  if (!stripeKey || stripeKey === 'sk_test_placeholder' || stripeKey === 'sk_test_xxx') {
    throw new Error('Stripe key not configured');
  }

  const { stripe } = await import('../../lib/stripe');
  const stripeProduct = await stripe.products.retrieve(id!);
  const prices = await stripe.prices.list({ product: id!, active: true, limit: 100 });

  const sizeOrder = ['XS', 'S', 'M', 'L', 'XL', 'XXL', '2XL', '3XL'];

  product = {
    id: stripeProduct.id,
    name: stripeProduct.name,
    description: stripeProduct.description?.split('\n')[0] || null,
    images: stripeProduct.images,
    sport: (stripeProduct.metadata?.sport || 'pickleball').toLowerCase(),
    prices: prices.data
      .map(p => ({
        id: p.id,
        amount: p.unit_amount || 0,
        currency: p.currency,
        size: p.metadata?.size || p.nickname || 'One Size',
      }))
      .sort((a, b) => sizeOrder.indexOf(a.size) - sizeOrder.indexOf(b.size)),
  };
  fullDescription = stripeProduct.description || '';
} catch (e) {
  isDemo = true;
  const found = findProduct(id!);
  if (found) {
    product = toCatalogItem(found);
    fullDescription = found.description;
  }
}

if (!product) {
  return Astro.redirect('/shop');
}

const lowestPrice = Math.min(...product.prices.map(p => p.amount));
const highestPrice = Math.max(...product.prices.map(p => p.amount));
const hasPriceRange = lowestPrice !== highestPrice;
---

<BaseLayout
  title={product.name}
  description={fullDescription?.split('\n')[0] || `Shop ${product.name} at Blackout Pickleball`}
>
  <section class="py-12 sm:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {isDemo && (
        <div class="mb-6 p-3 bg-gray-50 border border-gray-200 rounded-xl text-center">
          <p class="text-gray-700 text-sm font-medium">
            🏗️ Preview Mode — Real product photos coming soon.
          </p>
        </div>
      )}

      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-text-light">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li class="text-gray-300">/</li>
          <li><a href="/shop" class="hover:text-accent transition-colors">Shop</a></li>
          <li class="text-gray-300">/</li>
          <li class="text-text font-medium">{product.name}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Product Images / 360° Viewer -->
        <div>
          {product.images.length > 1 ? (
            <ProductViewer client:load images={product.images} productName={product.name} />
          ) : (
            <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-white">
              {product.images.length === 1 ? (
                <img
                  src={product.images[0]}
                  alt={product.name}
                  class="w-full h-full object-contain"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-surface-dark">
                  <div class="text-center">
                    <span class="text-8xl block mb-4">🏓</span>
                    <p class="text-text-light text-sm">Product image coming soon</p>
                  </div>
                </div>
              )}
            </div>
          )}
        </div>

        <!-- Product Details -->
        <div>
          {/* Color indicator */}
          {product.colorHex && (
            <div class="flex items-center gap-2 mb-3">
              <span
                class="w-4 h-4 rounded-full border border-gray-300 inline-block"
                style={`background-color: ${product.colorHex}`}
              />
              <span class="text-sm text-text-light font-medium">{product.colorName}</span>
            </div>
          )}

          <h1 class="text-3xl sm:text-4xl font-black tracking-tight">{product.name}</h1>

          <div class="mt-4">
            <span class="text-2xl font-black text-blackout">
              {hasPriceRange
                ? `$${(lowestPrice / 100).toFixed(2)} – $${(highestPrice / 100).toFixed(2)}`
                : `$${(lowestPrice / 100).toFixed(2)}`}
            </span>
          </div>

          {fullDescription && (
            <div class="mt-6 space-y-3">
              {fullDescription.split('\n').map((line) => (
                line.trim() ? (
                  <p class={`text-text-light leading-relaxed ${line.startsWith('•') ? 'pl-2' : ''}`}>
                    {line}
                  </p>
                ) : null
              ))}
            </div>
          )}

          <!-- Add to Cart -->
          <div class="mt-8 p-6 bg-gray-50 rounded-2xl">
            <AddToCartButton
              client:load
              productId={product.id}
              productName={product.name}
              productImage={product.images[0] || ''}
              prices={product.prices.map(p => ({
                id: p.id,
                amount: p.amount,
                size: p.size,
              }))}
            />
          </div>

          <!-- Product Features -->
          <div class="mt-8 grid grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">🚚</span>
              <div>
                <p class="text-xs font-semibold text-text">Free Shipping</p>
                <p class="text-xs text-text-light">Orders over $75</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">↩️</span>
              <div>
                <p class="text-xs font-semibold text-text">14-Day Returns</p>
                <p class="text-xs text-text-light">Easy exchanges</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">🔒</span>
              <div>
                <p class="text-xs font-semibold text-text">Secure Checkout</p>
                <p class="text-xs text-text-light">Powered by Stripe</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">⚡</span>
              <div>
                <p class="text-xs font-semibold text-text">Performance Fabric</p>
                <p class="text-xs text-text-light">Moisture-wicking</p>
              </div>
            </div>
          </div>

          <!-- Back to shop -->
          <div class="mt-8">
            <a href="/shop" class="text-sm text-text-light hover:text-accent transition-colors font-medium">
              ← Back to Shop
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="py-16 sm:py-20 bg-surface-warm border-t border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black tracking-tight mb-8">You May Also Like</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        {PRODUCT_CATALOG
          .filter(p => p.slug !== id)
          .sort(() => 0.5 - Math.random())
          .slice(0, 4)
          .map((rp) => (
            <a href={`/product/${rp.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-border hover:-translate-y-0.5">
              <div class="aspect-[4/5] bg-white overflow-hidden relative">
                <img
                  src={rp.images.thumbnail}
                  alt={rp.name}
                  class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-2 left-2">
                  <span
                    class="inline-block w-4 h-4 rounded-full border-2 border-white shadow-sm"
                    style={`background-color: ${rp.colorHex}`}
                    title={rp.colorName}
                  ></span>
                </div>
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="font-bold text-xs sm:text-sm group-hover:text-blackout transition-colors leading-tight line-clamp-2">{rp.name}</h3>
                <span class="text-sm font-black text-blackout mt-1 block">${(rp.prices[0].amount / 100).toFixed(2)}</span>
              </div>
            </a>
          ))}
      </div>
    </div>
  </section>
</BaseLayout>