---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AddToCartButton from '../../components/AddToCartButton';
import ProductViewer from '../../components/ProductViewer';
import type { CatalogItem } from '../../lib/stripe';

const { id } = Astro.params;

let product: CatalogItem | null = null;
let isDemo = false;

// Demo products for when Stripe isn't connected
const demoProducts: Record<string, CatalogItem> = {
  demo_tee: {
    id: 'demo_tee',
    name: 'Blackout Performance Tee',
    description: 'Premium court-ready tee — 85% Polyester / 15% Spandex. Breathable 4-way stretch fabric designed to release heat and wick moisture. Perfect shape recovery and extreme freedom of movement on the court.\n\nFeatures:\n• Moisture-wicking technology\n• 4-way stretch for unrestricted movement\n• Anti-odor treatment\n• Tagless comfort\n• Available in S through XXL',
    images: [],
    sport: 'pickleball',
    prices: [
      { id: 'demo_tee_s', amount: 3500, currency: 'usd', size: 'S' },
      { id: 'demo_tee_m', amount: 3500, currency: 'usd', size: 'M' },
      { id: 'demo_tee_l', amount: 3500, currency: 'usd', size: 'L' },
      { id: 'demo_tee_xl', amount: 3500, currency: 'usd', size: 'XL' },
      { id: 'demo_tee_xxl', amount: 3500, currency: 'usd', size: 'XXL' },
    ],
  },
  demo_hoodie: {
    id: 'demo_hoodie',
    name: 'Blackout Hoodie',
    description: 'Warm-up in style with our premium cotton blend hoodie. Featuring the Blackout Pickleball logo, adjustable drawstring hood, and kangaroo pocket.\n\nFeatures:\n• Premium cotton-poly blend\n• Adjustable drawstring hood\n• Kangaroo pocket\n• Ribbed cuffs and hem\n• Embroidered logo',
    images: [],
    sport: 'pickleball',
    prices: [
      { id: 'demo_hoodie_s', amount: 5500, currency: 'usd', size: 'S' },
      { id: 'demo_hoodie_m', amount: 5500, currency: 'usd', size: 'M' },
      { id: 'demo_hoodie_l', amount: 5500, currency: 'usd', size: 'L' },
      { id: 'demo_hoodie_xl', amount: 5500, currency: 'usd', size: 'XL' },
    ],
  },
  demo_cap: {
    id: 'demo_cap',
    name: 'Blackout Cap',
    description: 'Rep the brand on and off the court. Adjustable snapback with embroidered Blackout Pickleball logo.\n\nFeatures:\n• Structured mid-profile fit\n• Adjustable snapback closure\n• Embroidered logo\n• Curved brim\n• One size fits most',
    images: [],
    sport: 'pickleball',
    prices: [
      { id: 'demo_cap_one', amount: 2500, currency: 'usd', size: 'One Size' },
    ],
  },
  demo_shorts: {
    id: 'demo_shorts',
    name: 'Blackout Performance Shorts',
    description: 'Lightweight performance shorts built for tournament play. Deep side pockets for ball storage.\n\nFeatures:\n• Lightweight moisture-wicking fabric\n• Elastic waistband with drawstring\n• Deep side pockets\n• 7-inch inseam\n• Blackout logo print',
    images: [],
    sport: 'pickleball',
    prices: [
      { id: 'demo_shorts_s', amount: 4000, currency: 'usd', size: 'S' },
      { id: 'demo_shorts_m', amount: 4000, currency: 'usd', size: 'M' },
      { id: 'demo_shorts_l', amount: 4000, currency: 'usd', size: 'L' },
      { id: 'demo_shorts_xl', amount: 4000, currency: 'usd', size: 'XL' },
    ],
  },
};

try {
  const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
  if (!stripeKey || stripeKey === 'sk_test_placeholder' || stripeKey === 'sk_test_xxx') {
    throw new Error('Stripe key not configured');
  }
  
  const { stripe } = await import('../../lib/stripe');
  const stripeProduct = await stripe.products.retrieve(id!);
  const prices = await stripe.prices.list({ product: id!, active: true, limit: 100 });
  
  const sizeOrder = ['XS', 'S', 'M', 'L', 'XL', 'XXL', '2XL', '3XL'];
  
  product = {
    id: stripeProduct.id,
    name: stripeProduct.name,
    description: stripeProduct.description,
    images: stripeProduct.images,
    sport: (stripeProduct.metadata?.sport || 'pickleball').toLowerCase(),
    prices: prices.data
      .map(p => ({
        id: p.id,
        amount: p.unit_amount || 0,
        currency: p.currency,
        size: p.metadata?.size || p.nickname || 'One Size',
      }))
      .sort((a, b) => sizeOrder.indexOf(a.size) - sizeOrder.indexOf(b.size)),
  };
} catch (e) {
  isDemo = true;
  product = demoProducts[id!] || null;
}

if (!product) {
  return Astro.redirect('/shop');
}

const lowestPrice = Math.min(...product.prices.map(p => p.amount));
const highestPrice = Math.max(...product.prices.map(p => p.amount));
const hasPriceRange = lowestPrice !== highestPrice;
---

<BaseLayout
  title={product.name}
  description={product.description?.split('\n')[0] || `Shop ${product.name} at Blackout Pickleball`}
>
  <section class="py-12 sm:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {isDemo && (
        <div class="mb-6 p-3 bg-amber-50 border border-amber-200 rounded-xl text-center">
          <p class="text-amber-800 text-sm font-medium">
            🏗️ Preview Mode — This is a demo product.
          </p>
        </div>
      )}

      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-text-light">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li class="text-gray-300">/</li>
          <li><a href="/shop" class="hover:text-accent transition-colors">Shop</a></li>
          <li class="text-gray-300">/</li>
          <li class="text-text font-medium">{product.name}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Product Images / 360° Viewer -->
        <div>
          {product.images.length > 1 ? (
            <ProductViewer client:load images={product.images} productName={product.name} />
          ) : (
            <div class="aspect-square rounded-2xl overflow-hidden bg-gradient-to-br from-gray-100 to-gray-200">
              {product.images.length === 1 ? (
                <img
                  src={product.images[0]}
                  alt={product.name}
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-surface-dark">
                  <div class="text-center">
                    <span class="text-8xl block mb-4">🏓</span>
                    <p class="text-text-light text-sm">Product image coming soon</p>
                  </div>
                </div>
              )}
            </div>
          )}
        </div>

        <!-- Product Details -->
        <div>
          <h1 class="text-3xl sm:text-4xl font-black tracking-tight">{product.name}</h1>
          
          <div class="mt-4">
            <span class="text-2xl font-black text-blackout">
              {hasPriceRange
                ? `$${(lowestPrice / 100).toFixed(2)} – $${(highestPrice / 100).toFixed(2)}`
                : `$${(lowestPrice / 100).toFixed(2)}`}
            </span>
          </div>

          {product.description && (
            <div class="mt-6 space-y-3">
              {product.description.split('\n').map((line) => (
                line.trim() ? (
                  <p class={`text-text-light leading-relaxed ${line.startsWith('•') ? 'pl-2' : ''}`}>
                    {line}
                  </p>
                ) : null
              ))}
            </div>
          )}

          <!-- Add to Cart -->
          <div class="mt-8 p-6 bg-gray-50 rounded-2xl">
            <AddToCartButton
              client:load
              productId={product.id}
              productName={product.name}
              productImage={product.images[0] || ''}
              prices={product.prices.map(p => ({
                id: p.id,
                amount: p.amount,
                size: p.size,
              }))}
            />
          </div>

          <!-- Product Features -->
          <div class="mt-8 grid grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">🚚</span>
              <div>
                <p class="text-xs font-semibold text-text">Free Shipping</p>
                <p class="text-xs text-text-light">Orders over $75</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">↩️</span>
              <div>
                <p class="text-xs font-semibold text-text">14-Day Returns</p>
                <p class="text-xs text-text-light">Easy exchanges</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">🔒</span>
              <div>
                <p class="text-xs font-semibold text-text">Secure Checkout</p>
                <p class="text-xs text-text-light">Powered by Stripe</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
              <span class="text-lg">⚡</span>
              <div>
                <p class="text-xs font-semibold text-text">Performance Fabric</p>
                <p class="text-xs text-text-light">85% Poly / 15% Spandex</p>
              </div>
            </div>
          </div>

          <!-- Back to shop -->
          <div class="mt-8">
            <a href="/shop" class="text-sm text-text-light hover:text-accent transition-colors font-medium">
              ← Back to Shop
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
