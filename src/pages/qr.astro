---
import BaseLayout from '../layouts/BaseLayout.astro';

// Not linked from nav — internal/print use only
---

<BaseLayout title="QR Codes">
  <main class="min-h-screen bg-surface py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Page header -->
      <div class="text-center mb-16">
        <h1 class="font-display text-4xl sm:text-5xl font-semibold tracking-tight text-blackout mb-4">
          QR Code Materials
        </h1>
        <p class="text-text-light text-lg max-w-xl mx-auto">
          Printable branded QR code posters for events, storefronts, and marketing materials.
        </p>
      </div>

      <!-- Two poster cards -->
      <div class="grid md:grid-cols-2 gap-12 mb-16">
        <!-- Visit poster -->
        <div class="group">
          <div class="bg-white border border-border rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <img
              src="/assets/qr/poster-visit.svg"
              alt="Blackout — Visit Us QR code poster"
              class="w-full h-auto"
              loading="eager"
            />
          </div>
          <div class="mt-4 text-center">
            <h2 class="font-display text-xl font-semibold text-blackout mb-1">Visit Us</h2>
            <p class="text-text-light text-sm mb-3">Links to brandblackout.com</p>
            <a
              href="/assets/qr/poster-visit.svg"
              download="blackout-qr-visit.svg"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-blackout text-text-inverse text-sm font-medium rounded-md hover:bg-blackout-light transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Download SVG
            </a>
          </div>
        </div>

        <!-- Shop poster -->
        <div class="group">
          <div class="bg-white border border-border rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <img
              src="/assets/qr/poster-shop.svg"
              alt="Blackout — Shop Now QR code poster"
              class="w-full h-auto"
              loading="eager"
            />
          </div>
          <div class="mt-4 text-center">
            <h2 class="font-display text-xl font-semibold text-blackout mb-1">Shop Now</h2>
            <p class="text-text-light text-sm mb-3">Links to brandblackout.com/shop</p>
            <a
              href="/assets/qr/poster-shop.svg"
              download="blackout-qr-shop.svg"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-blackout text-text-inverse text-sm font-medium rounded-md hover:bg-blackout-light transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Download SVG
            </a>
          </div>
        </div>
      </div>

      <!-- Print instructions -->
      <div class="bg-surface-dark rounded-lg p-8 text-center">
        <h3 class="font-display text-lg font-semibold text-blackout mb-2">Print Instructions</h3>
        <p class="text-text-light text-sm max-w-lg mx-auto leading-relaxed">
          These SVG files are resolution-independent and can be printed at any size without quality loss.
          For best results, print on premium matte or glossy paper at 8.5" × 11" or larger.
          The QR codes use high error correction — they'll scan reliably even from a distance.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>
