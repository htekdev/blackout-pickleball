---
import AdminLayout from '../../layouts/AdminLayout.astro';
import EventManager from '../../components/admin/EventManager';
import eventsData from '../../data/events.json';
---

<AdminLayout title="Event Management">
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-black font-display tracking-tight">Event Management</h1>
        <p class="mt-1 text-text-light">Create, edit, and manage all Blackout events.</p>
      </div>
    </div>

    <!-- Event Manager (Preact Island) -->
    <EventManager client:only="preact" initialEvents={eventsData} />
  </div>
</AdminLayout>
