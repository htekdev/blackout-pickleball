---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="space-y-8">
    <!-- Page Header -->
    <div>
      <h1 class="text-3xl font-black font-display tracking-tight">Admin Dashboard</h1>
      <p class="mt-2 text-text-light">Manage your Blackout Pickleball website content.</p>
    </div>

    <!-- Quick Actions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Events Card -->
      <a href="/admin/events" class="group bg-white rounded-xl border border-border p-6 hover:shadow-lg hover:border-blackout/20 transition-all duration-200">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-blackout/5 rounded-lg flex items-center justify-center group-hover:bg-blackout/10 transition-colors">
            <svg class="w-6 h-6 text-blackout" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-blackout group-hover:text-blackout-light transition-colors">Events</h2>
            <p class="text-sm text-text-light">Create, edit, and manage events</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 text-sm text-text-light group-hover:text-blackout transition-colors">
          <span>Manage events</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Shop Card -->
      <div class="bg-white rounded-xl border border-border p-6 opacity-60">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-surface-dark rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-text-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-text-light">Shop</h2>
            <p class="text-sm text-text-light">Managed via Stripe Dashboard</p>
          </div>
        </div>
        <div class="mt-4 text-xs text-text-light bg-surface-dark rounded px-2 py-1 inline-block">
          Products auto-discovered from Stripe
        </div>
      </div>

      <!-- Site Info Card -->
      <div class="bg-white rounded-xl border border-border p-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-blackout">Site Status</h2>
            <p class="text-sm text-green-600 font-medium">Live & Healthy</p>
          </div>
        </div>
        <div class="mt-4 text-sm text-text-light">
          <a href="https://www.brandblackout.com" target="_blank" class="hover:text-blackout transition-colors underline">brandblackout.com →</a>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <div class="bg-white rounded-xl border border-border p-6">
      <h3 class="text-lg font-bold mb-3">How Admin Works</h3>
      <div class="grid md:grid-cols-3 gap-4 text-sm text-text-light">
        <div class="flex gap-3">
          <span class="w-6 h-6 bg-blackout text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">1</span>
          <p>Make changes in the admin panel — create events, edit details, toggle visibility.</p>
        </div>
        <div class="flex gap-3">
          <span class="w-6 h-6 bg-blackout text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">2</span>
          <p>Changes save to your browser automatically. Use "Export JSON" to download your data.</p>
        </div>
        <div class="flex gap-3">
          <span class="w-6 h-6 bg-blackout text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">3</span>
          <p>Send the exported file to Hector to publish changes to the live site.</p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
