---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Events" description="Upcoming Blackout Pickleball events, tournaments, and community gatherings.">

  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Upcoming Events</p>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight">Play with Us</h1>
        <p class="mt-4 text-text-light text-lg">Join the Blackout Pickleball community at our upcoming events.</p>
      </div>

      <!-- Event Card Placeholder -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-gradient-to-r from-blackout to-blackout-light p-8 text-text-inverse">
          <span class="text-accent text-sm font-semibold uppercase tracking-widest">Coming Soon</span>
          <h2 class="text-2xl font-black mt-2">Blackout Community Mixer</h2>
          <p class="text-white/70 mt-2">Details coming soon — follow us on social media for updates!</p>
        </div>
        <div class="p-6">
          <p class="text-text-light">
            We're planning exciting community events for pickleball players of all levels. Stay tuned for dates, locations, and registration details.
          </p>
          <div class="mt-4 flex gap-4">
            <a href="https://www.instagram.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent-dark font-medium transition-colors">
              Follow on Instagram &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
