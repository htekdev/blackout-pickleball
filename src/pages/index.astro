---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Blackout Pickleball — Celebrate Diversity. Play with Purpose. Performance gear and community events for pickleball players who play bold.">

  <!-- Hero Section -->
  <section class="relative bg-blackout text-text-inverse overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blackout via-blackout-light to-blackout opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-3xl">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Celebrate Diversity. Play with Purpose.</p>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black leading-tight tracking-tight">
          Play Bold.<br />
          <span class="text-accent">Play Blackout.</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-white/70 max-w-xl">
          Performance gear engineered for the heat of the game. Premium fabrics, bold designs, built for the court.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/shop" class="inline-flex items-center justify-center px-8 py-3 bg-accent hover:bg-accent-dark text-blackout font-bold rounded-lg transition-colors text-sm uppercase tracking-wider">
            Shop Merch
          </a>
          <a href="/about" class="inline-flex items-center justify-center px-8 py-3 border-2 border-white/30 hover:border-accent text-white hover:text-accent font-bold rounded-lg transition-colors text-sm uppercase tracking-wider">
            Join the Tribe
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-text tracking-tight">Performance Gear</h2>
        <p class="mt-3 text-text-light max-w-xl mx-auto">Engineered for the heat of the game. 85% Polyester / 15% Spandex — breathable, 4-way stretch, moisture-wicking.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Placeholder product cards — will be replaced with real products -->
        {[
          { name: 'Blackout Performance Tee', price: '$35.00', desc: 'Premium court-ready tee' },
          { name: 'Blackout Hoodie', price: '$55.00', desc: 'Warm-up in style' },
          { name: 'Blackout Cap', price: '$25.00', desc: 'Rep the brand on court' },
        ].map((product) => (
          <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-gray-100">
            <div class="aspect-square bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
              <span class="text-4xl">🏓</span>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-lg">{product.name}</h3>
              <p class="text-sm text-text-light mt-1">{product.desc}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="font-bold text-accent-dark">{product.price}</span>
                <a href="/shop" class="text-sm font-medium text-accent hover:text-accent-dark transition-colors">Shop Now &rarr;</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brand Story Snippet -->
  <section class="py-16 sm:py-24 bg-blackout text-text-inverse">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight">A Vibrant Space for Everyone</h2>
        <p class="mt-6 text-lg text-white/70">
          We celebrate diversity and inclusivity at Blackout Pickleball. We're dedicated to increasing Black representation in the sport while welcoming everyone — regardless of background — to join us in playing, supporting, and sharing the game.
        </p>
        <a href="/about" class="inline-flex items-center mt-8 text-accent hover:text-accent-light font-semibold transition-colors">
          Learn Our Story &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Community CTA -->
  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-black text-text tracking-tight">Join the Community</h2>
      <p class="mt-3 text-text-light max-w-xl mx-auto">
        Real players. Real performance. Join the community that's bringing diversity and vibrant energy to the court.
      </p>
      <div class="mt-8 flex justify-center gap-6">
        <a href="https://www.instagram.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm font-medium">Instagram</a>
        <a href="https://www.facebook.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm font-medium">Facebook</a>
        <a href="https://www.tiktok.com/@blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-text-light hover:text-accent transition-colors text-sm font-medium">TikTok</a>
      </div>
    </div>
  </section>

</BaseLayout>
