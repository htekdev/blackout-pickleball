---
import BaseLayout from '../layouts/BaseLayout.astro';

// Community gallery — Jonathan's curated selection (10 photos from Google Photos album)
// Mix of group shots, individual portraits, product showcases, and creative angles
// community-07 used as hero (full team group shot), remaining 9 in gallery
const galleryImages = [
  { src: '/images/community/community-05.webp', alt: 'Three Blackout athletes crouching at the net with paddles and pickleballs — squad goals', category: 'community' },
  { src: '/images/community/community-01.webp', alt: 'Blackout Pickleball athlete portrait — confident pose in long-sleeve', category: 'lifestyle' },
  { src: '/images/community/community-02.webp', alt: 'Blackout Pickleball athlete in branded gear — portrait on the court', category: 'lifestyle' },
  { src: '/images/community/community-06.webp', alt: 'Creative close-up — athlete with paddle and pickleballs in Blackout long-sleeve', category: 'product' },
  { src: '/images/community/community-03.webp', alt: 'Blackout Pickleball athlete styled portrait — court vibes', category: 'lifestyle' },
  { src: '/images/community/community-08.webp', alt: 'Blackout Pickleball individual portrait — repping the brand', category: 'lifestyle' },
  { src: '/images/community/community-04.webp', alt: 'Athlete portrait in Blackout gear — on the pickleball court', category: 'lifestyle' },
  { src: '/images/community/community-09.webp', alt: 'Blackout community member portrait — pickleball lifestyle', category: 'lifestyle' },
  { src: '/images/community/community-10.webp', alt: 'Blackout Pickleball athlete — styled portrait with paddle', category: 'lifestyle' },
];

const socialPlatforms = [
  {
    name: 'Instagram',
    handle: '@blackoutpickleball',
    url: 'https://www.instagram.com/blackoutpickleball/',
    followers: '5,100+',
    posts: '374',
    description: 'Our home base. Behind-the-scenes, event recaps, community spotlights, and new gear drops.',
    color: 'bg-gradient-to-br from-purple-500 via-pink-500 to-orange-400',
    icon: `<svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
    cta: 'Follow on Instagram',
    stat_label: 'followers',
    featured: true,
  },
  {
    name: 'TikTok',
    handle: '@blackoutpickleball',
    url: 'https://www.tiktok.com/@blackoutpicklebal',
    followers: null,
    posts: null,
    description: 'Quick clips, trick shots, event highlights, and the energy of the Blackout community in 60 seconds or less.',
    color: 'bg-black',
    icon: `<svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
    cta: 'Follow on TikTok',
    stat_label: null,
    featured: false,
  },
  {
    name: 'YouTube',
    handle: '@blackoutpickleball',
    url: 'https://www.youtube.com/@blackoutpickleball',
    followers: null,
    posts: null,
    description: 'Full-length event recaps, player interviews, gear reviews, and tournament highlights from the Blackout community.',
    color: 'bg-red-600',
    icon: `<svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    cta: 'Subscribe on YouTube',
    stat_label: null,
    featured: false,
  },
  {
    name: 'Facebook',
    handle: 'Blackout Pickleball',
    url: 'https://www.facebook.com/share/1Gy7bXFYp6/?mibextid=wwXIfr',
    followers: null,
    posts: null,
    description: 'Community discussions, event announcements, and connecting with Blackout players in your area.',
    color: 'bg-blue-600',
    icon: `<svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    cta: 'Like on Facebook',
    stat_label: null,
    featured: false,
  },
];
---

<BaseLayout title="Community" description="Join the Blackout community — follow us on Instagram, TikTok, YouTube, and Facebook. Stay connected with events, gear drops, and the movement.">

  <!-- Hero Section with Featured Group Photo -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 font-semibold text-sm uppercase tracking-widest mb-3">Join the Movement</p>
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-black">Our Community</h1>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Blackout is more than a brand — it's a community of athletes, advocates, and allies celebrating diversity across sports. Follow us, share your game, and be part of the movement.
      </p>
    </div>
  </section>

  <!-- Featured Community Photo — Full Width -->
  <section class="bg-white pb-8 sm:pb-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative group overflow-hidden rounded-2xl shadow-xl">
        <img
          src="/images/community/community-07.webp"
          alt="The Blackout Pickleball team — seven athletes standing together at the net, all repping Blackout gear on the court"
          loading="eager"
          decoding="async"
          class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.02]"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-10">
          <p class="text-white/80 text-xs sm:text-sm font-semibold uppercase tracking-widest mb-2">Blackout Chicago</p>
          <p class="text-white text-lg sm:text-2xl font-bold max-w-2xl">
            This is what community looks like. Athletes from all walks of life, united by the love of the game.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Community Photo Gallery -->
  <section class="py-12 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gray-500 font-semibold text-sm uppercase tracking-widest mb-3">Real People. Real Energy.</p>
        <h2 class="text-3xl sm:text-4xl font-black text-black">From the Courts & Beyond</h2>
        <p class="mt-3 text-gray-600 max-w-xl mx-auto">
          Events, day parties, photoshoots, and the everyday moments that make Blackout special.
        </p>
      </div>

      <!-- Masonry-style photo grid (curated for variety — max 1 photo per look/setting) -->
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {galleryImages.map((image, index) => (
          <div class="break-inside-avoid group relative overflow-hidden rounded-xl cursor-pointer">
            <img
              src={image.src}
              alt={image.alt}
              loading={index < 6 ? 'eager' : 'lazy'}
              decoding="async"
              class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 rounded-xl"></div>
            <div class="absolute inset-0 flex items-end p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-white text-sm font-medium drop-shadow-lg">{image.alt}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-8 text-center text-sm text-gray-400">
        {galleryImages.length + 1} photos from Jonathan's curated collection — community first
      </p>
    </div>
  </section>

  <!-- Instagram Feature — Primary Platform -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-5 py-2 mb-6">
          <svg class="h-5 w-5 text-pink-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <span class="text-sm font-semibold text-gray-800">@blackoutpickleball</span>
          <span class="text-xs text-gray-400">•</span>
          <span class="text-sm font-bold text-black">5,100+ followers</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-black">Follow Us on Instagram</h2>
        <p class="mt-3 text-gray-600 max-w-xl mx-auto">
          Our most active platform — 374 posts and counting. Event recaps, gear drops, community highlights, and more.
        </p>
      </div>

      <!-- Instagram Embed -->
      <div class="max-w-lg mx-auto bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
        <div class="p-6 text-center">
          <div class="w-24 h-24 mx-auto rounded-full bg-gradient-to-br from-purple-500 via-pink-500 to-orange-400 p-[3px] mb-4">
            <div class="w-full h-full rounded-full bg-white flex items-center justify-center">
              <img
                src="/assets/logo/blackout-only-black.svg"
                alt="Blackout"
                class="h-10 w-auto"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-black">@blackoutpickleball</h3>
          <p class="text-sm text-gray-500 mt-1">Celebrate Diversity. Play with Purpose. 🏓</p>

          <div class="flex justify-center gap-8 mt-5 py-4 border-y border-gray-100">
            <div class="text-center">
              <p class="text-xl font-bold text-black">374</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide">Posts</p>
            </div>
            <div class="text-center">
              <p class="text-xl font-bold text-black">5.1K</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide">Followers</p>
            </div>
            <div class="text-center">
              <p class="text-xl font-bold text-black">2.1K</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide">Following</p>
            </div>
          </div>

          <a
            href="https://www.instagram.com/blackoutpickleball/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex items-center justify-center w-full px-6 py-3 bg-black text-white font-semibold rounded-xl hover:bg-gray-800 transition-colors gap-2"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            Follow @blackoutpickleball
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- All Platforms Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gray-500 font-semibold text-sm uppercase tracking-widest mb-3">Stay Connected</p>
        <h2 class="text-3xl sm:text-4xl font-black text-black">Find Us Everywhere</h2>
        <p class="mt-3 text-gray-600 max-w-xl mx-auto">
          Follow Blackout across all platforms and never miss a beat.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {socialPlatforms.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative bg-white border border-gray-200 rounded-2xl p-6 hover:border-gray-300 hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div class={`${platform.color} text-white p-3 rounded-xl shrink-0`}>
                <Fragment set:html={platform.icon} />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-lg font-bold text-black">{platform.name}</h3>
                  {platform.followers && (
                    <span class="text-xs font-semibold text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
                      {platform.followers} {platform.stat_label}
                    </span>
                  )}
                </div>
                <p class="text-sm font-medium text-gray-500 mb-2">{platform.handle}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{platform.description}</p>
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm font-semibold text-black group-hover:gap-3 transition-all">
              {platform.cta}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Values -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-gray-500 font-semibold text-sm uppercase tracking-widest mb-3">What We Stand For</p>
        <h2 class="text-3xl sm:text-4xl font-black text-black">Built on Community</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-2">Diversity</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Increasing Black representation in sports while welcoming everyone — regardless of background — to the court.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-2">Inclusivity</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            A vibrant, welcoming space for every player — from beginners picking up their first paddle to seasoned competitors.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-black rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-2">Purpose</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Every match, every event, every piece of gear supports a bigger mission — changing the face of sports, one game at a time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-black text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-black">Ready to Join the Tribe?</h2>
      <p class="mt-4 text-lg text-gray-300 max-w-xl mx-auto">
        Follow us on social media, rep the gear, and help us celebrate diversity across every sport.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/shop"
          class="inline-flex items-center justify-center px-8 py-3 bg-white text-black font-semibold rounded-xl hover:bg-gray-100 transition-colors"
        >
          Shop the Collection
        </a>
        <a
          href="/events"
          class="inline-flex items-center justify-center px-8 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white hover:text-black transition-colors"
        >
          Upcoming Events
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
