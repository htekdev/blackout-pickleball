---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Get Involved" description="Join the Blackout movement ΓÇö sponsor events, volunteer your time, donate to the cause, or request Blackout sponsorship for your community.">

  <!-- Hero Banner -->
  <section class="relative bg-blackout text-white py-20 sm:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-white"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] rounded-full border border-white"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/60 font-semibold text-sm uppercase tracking-[0.2em] mb-4">Be Part of the Movement</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight font-display">Get Involved</h1>
      <p class="mt-6 text-lg sm:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">
        Blackout is powered by community. Whether you want to sponsor, volunteer, donate, or bring Blackout to your city ΓÇö there's a place for you.
      </p>
    </div>
  </section>

  <!-- Ways to Get Involved -->
  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section Intro -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-3 mb-6">
          <span class="w-10 h-px bg-blackout"></span>
          <span class="text-muted font-semibold text-xs uppercase tracking-[0.2em]">How You Can Help</span>
          <span class="w-10 h-px bg-blackout"></span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight font-display">Four Ways to Make an Impact</h2>
        <p class="mt-4 text-text-light text-lg max-w-2xl mx-auto">
          Every contribution ΓÇö big or small ΓÇö helps us grow the movement and create more inclusive spaces in sports.
        </p>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Sponsor Blackout -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blackout/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blackout" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Sponsor Blackout</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Partner with us to bring inclusive sports events to communities across the country. Sponsors help fund venues, equipment, prizes, and marketing to reach new players.
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Brand visibility at events & on merch</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Social media features & shoutouts</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Alignment with diversity & inclusion values</span>
            </li>
          </ul>
          <a href="mailto:blackoutpickleball@gmail.com?subject=Sponsorship%20Inquiry" class="inline-flex items-center gap-2 text-sm font-semibold text-blackout hover:text-text-light transition-colors uppercase tracking-wider">
            Inquire About Sponsorship
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <!-- Donate -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blackout/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blackout" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Donate</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Your donations directly fund community events, provide equipment for underserved areas, and help cover costs so everyone can play ΓÇö regardless of their financial situation.
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Fund event venues & equipment</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Subsidize tickets for underserved communities</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>100% goes toward the mission</span>
            </li>
          </ul>
          <a href="mailto:blackoutpickleball@gmail.com?subject=Donation%20Inquiry" class="inline-flex items-center gap-2 text-sm font-semibold text-blackout hover:text-text-light transition-colors uppercase tracking-wider">
            Make a Donation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <!-- Volunteer -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blackout/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blackout" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Volunteer</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Help run events, manage registrations, set up courts, capture content, or teach new players. Volunteers are the backbone of every Blackout event.
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Event setup, registration & logistics</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Photography & content creation</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Coaching & welcoming new players</span>
            </li>
          </ul>
          <a href="mailto:blackoutpickleball@gmail.com?subject=Volunteer%20Sign-Up" class="inline-flex items-center gap-2 text-sm font-semibold text-blackout hover:text-text-light transition-colors uppercase tracking-wider">
            Sign Up to Volunteer
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <!-- Request Blackout Sponsorship -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blackout/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blackout" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Request Blackout Sponsorship</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Running an event or building a community in your city? Request Blackout sponsorship ΓÇö we provide branded gear, promotional support, and co-marketing to help you bring the movement to your court.
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Branded gear & equipment for your event</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Co-marketing & social promotion</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blackout mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span>Join the national Blackout network</span>
            </li>
          </ul>
          <a href="mailto:blackoutpickleball@gmail.com?subject=Sponsorship%20Request%20for%20My%20Event" class="inline-flex items-center gap-2 text-sm font-semibold text-blackout hover:text-text-light transition-colors uppercase tracking-wider">
            Request Sponsorship
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Community Photo Strip -->
  <section class="py-12 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-3 md:grid-cols-5 gap-2 rounded-xl overflow-hidden">
        <div class="aspect-square overflow-hidden">
          <img src="/images/community/community-05.webp" alt="Blackout athletes at the net" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/community/community-01.webp" alt="Blackout athlete portrait" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/community/community-07.webp" alt="Blackout team group shot" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden hidden md:block">
          <img src="/images/community/community-03.webp" alt="Blackout Pickleball court vibes" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden hidden md:block">
          <img src="/images/community/community-08.webp" alt="Blackout community member" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-24 bg-blackout text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight font-display mb-6">Ready to Join the Movement?</h2>
      <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
        Whether you pick up a paddle, sponsor an event, or spread the word ΓÇö you're helping build a more inclusive sports community. Let's grow this together.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/events" class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-blackout font-bold text-sm uppercase tracking-wider rounded-full hover:bg-gray-100 transition-colors">
          See Upcoming Events
        </a>
        <a href="mailto:blackoutpickleball@gmail.com?subject=I%20Want%20to%20Get%20Involved" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-white text-white font-bold text-sm uppercase tracking-wider rounded-full hover:bg-white hover:text-blackout transition-colors">
          Contact Us
        </a>
      </div>
      <div class="mt-10 flex justify-center gap-6">
        <a href="https://www.instagram.com/blackoutpickleball" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="Instagram">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/share/1Gy7bXFYp6/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="Facebook">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@blackoutpicklebal" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="TikTok">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
        <a href="https://www.youtube.com/@BlackoutPickleball" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="YouTube">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
