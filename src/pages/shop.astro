---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shop" description="Shop Blackout Pickleball performance gear — tees, hoodies, hats and more.">

  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Performance Gear</p>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight">Shop</h1>
        <p class="mt-4 text-text-light text-lg max-w-xl mx-auto">Engineered for the heat of the game. Browse our full collection of performance pickleball gear.</p>
      </div>

      <!-- Product grid placeholder — will be replaced with Stripe API data -->
      <div class="bg-blackout/5 rounded-2xl p-12 text-center">
        <span class="text-5xl mb-4 block">🏓</span>
        <h2 class="text-2xl font-bold mb-2">Products Coming Soon</h2>
        <p class="text-text-light max-w-md mx-auto">
          Our merch store is being set up! Products will appear here automatically once connected to Stripe.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
