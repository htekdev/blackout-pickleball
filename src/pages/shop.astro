---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import AddToCartButton from '../components/AddToCartButton';
import { getCatalog, type CatalogItem } from '../lib/stripe';
import { PRODUCT_CATALOG, toCatalogItem } from '../lib/products';

// Read category filter from query param
const url = new URL(Astro.request.url);
const activeCategory = (url.searchParams.get('category') || 'all').toLowerCase();

// Sport categories config
const categories = [
  { id: 'all', label: 'All', active: true },
  { id: 'pickleball', label: 'Pickleball', active: true },
  { id: 'tennis', label: 'Tennis', active: false, comingSoon: true },
];

let catalog: (CatalogItem & { colorName?: string; colorHex?: string; category?: string })[] = [];
let isDemo = false;

try {
  const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
  if (!stripeKey || stripeKey === 'sk_test_placeholder' || stripeKey === 'sk_test_xxx') {
    throw new Error('Stripe key not configured');
  }
  catalog = await getCatalog();
} catch (e) {
  isDemo = true;
  // Real product catalog with 12 items and local 360° images
  catalog = PRODUCT_CATALOG.map(toCatalogItem);
}

// Filter catalog by sport category
let filteredCatalog = activeCategory === 'all'
  ? catalog
  : catalog.filter(p => p.sport === activeCategory);

function getLowestPrice(prices: CatalogItem['prices']): number {
  return Math.min(...prices.map(p => p.amount));
}

function formatPrice(cents: number): string {
  return `$${(cents / 100).toFixed(2)}`;
}
---

<BaseLayout title="Shop" description="Shop Blackout performance gear — tees, hoodies, hats and more across all sports.">

  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-muted font-semibold text-sm uppercase tracking-widest mb-3">Performance Gear</p>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight font-display">Shop</h1>
        <p class="mt-4 text-text-light text-lg max-w-xl mx-auto">Engineered for the heat of the game. Browse our full collection of Blackout performance gear.</p>
      </div>

      {/* Sport Category Filter Pills */}
      <div class="flex justify-center mb-10">
        <nav class="inline-flex items-center gap-2 p-1.5 bg-gray-100 rounded-full" aria-label="Filter by sport">
          {categories.map((cat) => {
            const isActive = activeCategory === cat.id;
            const isDisabled = cat.comingSoon;
            const href = cat.id === 'all' ? '/shop' : `/shop?category=${cat.id}`;

            return isDisabled ? (
              <span
                class="relative px-5 py-2 rounded-full text-sm font-medium text-gray-400 cursor-not-allowed select-none"
                title="Coming Soon"
              >
                {cat.label}
                <span class="ml-1.5 inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-semibold bg-gray-200 text-gray-500 uppercase tracking-wide">
                  Soon
                </span>
              </span>
            ) : (
              <a
                href={href}
                class:list={[
                  'px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200',
                  isActive
                    ? 'bg-blackout text-white shadow-sm'
                    : 'text-gray-600 hover:text-blackout hover:bg-white',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {cat.label}
              </a>
            );
          })}
        </nav>
      </div>

      {isDemo && (
        <div class="mb-8 p-4 bg-gray-50 border border-gray-200 rounded-xl text-center">
          <p class="text-gray-700 text-sm font-medium">
            🏗️ Preview Mode — Real product photos coming soon. Multi-angle viewer active on product pages.
          </p>
        </div>
      )}

      <!-- Product Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
        {filteredCatalog.map((product) => (
          <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-border">
            {/* Product Image */}
            <a href={`/product/${product.id}`} class="block">
              <div class="aspect-[4/5] bg-white overflow-hidden relative">
                {product.images.length > 0 ? (
                  <img
                    src={product.images[0]}
                    alt={product.name}
                    class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-surface-dark">
                    <span class="text-5xl opacity-60">🏓</span>
                  </div>
                )}
                {/* Color swatch badge */}
                {product.colorHex && (
                  <div class="absolute top-3 left-3 flex items-center gap-1.5 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-full">
                    <span
                      class="w-3 h-3 rounded-full border border-gray-300 inline-block"
                      style={`background-color: ${product.colorHex}`}
                    />
                    <span class="text-[10px] font-medium text-gray-600">{product.colorName}</span>
                  </div>
                )}
                {/* Multi-angle badge */}
                {product.images.length > 1 && (
                  <div class="absolute bottom-3 right-3 bg-black/70 text-white text-[10px] font-bold px-2 py-1 rounded-full flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14" /></svg>
                    {product.images.length}
                  </div>
                )}
              </div>
            </a>

            {/* Product Info */}
            <div class="p-3 sm:p-4">
              <a href={`/product/${product.id}`} class="block">
                <h3 class="font-bold text-sm sm:text-base group-hover:text-blackout transition-colors line-clamp-2">{product.name}</h3>
              </a>
              <div class="mt-1.5">
                <span class="text-base sm:text-lg font-black text-blackout">
                  {product.prices.length > 1 && getLowestPrice(product.prices) !== Math.max(...product.prices.map(p => p.amount))
                    ? `From ${formatPrice(getLowestPrice(product.prices))}`
                    : formatPrice(getLowestPrice(product.prices))}
                </span>
              </div>

              {/* Add to Cart (Preact island) */}
              <AddToCartButton
                client:load
                productId={product.id}
                productName={product.name}
                productImage={product.images[0] || ''}
                prices={product.prices.map(p => ({
                  id: p.id,
                  amount: p.amount,
                  size: p.size,
                }))}
              />
            </div>
          </div>
        ))}
      </div>

      {filteredCatalog.length === 0 && !isDemo && (
        <div class="bg-blackout/5 rounded-2xl p-12 text-center">
          <span class="text-5xl mb-4 block">🏓</span>
          {activeCategory !== 'all' ? (
            <>
              <h2 class="text-2xl font-bold mb-2">No {activeCategory.charAt(0).toUpperCase() + activeCategory.slice(1)} Products Yet</h2>
              <p class="text-text-light max-w-md mx-auto mb-4">
                Products for this sport will appear here as they're added. Check out our full collection in the meantime.
              </p>
              <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 bg-blackout text-white rounded-full font-semibold hover:bg-blackout/90 transition-colors">
                View All Products
              </a>
            </>
          ) : (
            <>
              <h2 class="text-2xl font-bold mb-2">No Products Yet</h2>
              <p class="text-text-light max-w-md mx-auto">
                Products will appear here automatically once they're added to the Stripe catalog.
              </p>
            </>
          )}
        </div>
      )}

      {filteredCatalog.length === 0 && isDemo && activeCategory !== 'all' && activeCategory !== 'pickleball' && (
        <div class="bg-blackout/5 rounded-2xl p-12 text-center">
          <span class="text-5xl mb-4 block">🎾</span>
          <h2 class="text-2xl font-bold mb-2">{activeCategory.charAt(0).toUpperCase() + activeCategory.slice(1)} — Coming Soon</h2>
          <p class="text-text-light max-w-md mx-auto mb-4">
            We're expanding to new sports. Stay tuned for {activeCategory} gear!
          </p>
          <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 bg-blackout text-white rounded-full font-semibold hover:bg-blackout/90 transition-colors">
            View All Products
          </a>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
